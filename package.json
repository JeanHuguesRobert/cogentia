{
  "name": "cogentia",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "personal:dev": "pnpm --filter @cogentia/personal run dev",
    "personal:build": "pnpm --filter @cogentia/personal run build",
    "commons:dev": "pnpm --filter @cogentia/commons run dev",
    "commons:build": "pnpm --filter @cogentia/commons run build",
    "cogentia": "node scripts/cogentia.js",
    "test:context": "node scripts/test-context-gateway.js",
    "test:ai-router": "node scripts/test-ai-router-client.js",
    "trace:import:chatgpt": "node trace/scripts/import_chatgpt_export.js"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
