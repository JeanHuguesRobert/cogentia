    "commons:build": "pnpm --filter @cogentia/commons run build",
    "cogentia": "node scripts/cogentia.js",
    "test:context": "node scripts/test-context-gateway.js",
    "test:guide": "node scripts/test-guide-http.js",
    "test:retrieval-inox": "node scripts/test-retrieval-inox-session.js",
    "test:blackboard": "node scripts/test-packet-attractor-blackboard.js",
    "test:guide-cli": "node scripts/test-guide-cli.js",
    "test:guide-eval": "node scripts/test-guide-eval.js",
    "test:ai-router": "node scripts/test-ai-router-client.js",
    "test:smart-embed": "node scripts/test-smart-embed-worker.js",
    "test:embedding-step": "node scripts/test-embedding-step.js",
    "test:semantic-worker": "node scripts/test-semantic-search-worker.js",
    "test:query-cache": "node scripts/test-query-embedding-cache.js",
